{
  "name": "@loremem/cli",
  "version": "1.3.22-pre.3",
  "description": "Interactive installer and manager for Lore agent runtime integrations",
  "type": "module",
  "bin": {
    "loremem": "dist/bin.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "node --import tsx --test test/**/*.test.ts",
    "prepublishOnly": "npm run typecheck && npm test && npm run build"
  },
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/FFatTiger/lore.git",
    "directory": "cli"
  },
  "devDependencies": {
    "@types/cross-spawn": "^6.0.6",
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.9.0"
  },
  "dependencies": {
    "@clack/prompts": "^1.7.0",
    "cross-spawn": "^7.0.6",
    "fflate": "^0.8.3"
  }
}
