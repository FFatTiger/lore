{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume|clear",
        "hooks": [
          {
            "type": "command",
            "command": "node \"__LORE_CODEX_PLUGIN_ROOT__/hooks/rules-inject.mjs\"",
            "timeout": 10,
            "statusMessage": "Loading Lore lifecycle context"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"__LORE_CODEX_PLUGIN_ROOT__/hooks/recall-inject.mjs\"",
            "timeout": 10,
            "statusMessage": "Recalling Lore context"
          }
        ]
      }
    ]
  }
}
